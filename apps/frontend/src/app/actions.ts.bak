// src/app/actions.ts
"use server";

import { db } from "@/lib/db";
import { revalidatePath } from "next/cache";
import { getRequiredUserId } from "@/lib/session";

/**
 * FETCH ACTIONS (Strictly Tenant-Scoped)
 * Cleanly coerces Decimal fields to standard numbers and satisfies frontend type expectations.
 */
export async function getDashboardData() {
  const userId = await getRequiredUserId();

  const rawLogs = await db.historyLog.findMany({
    where: {
      user_id: userId,
      stage: {
        not: "Telemetry Rollup"
      }
    },
    orderBy: { created_at: "desc" },
    take: 30,
  }) || [];

  const rawTelemetryPackets = await db.telemetryPacket.findMany({
    where: { userId: userId },
    orderBy: { recordedAt: "desc" },
    take: 60,
  }) || [];

  const chronologicalLogs = [...rawLogs].reverse();
  const chronologicalTelemetry = [...rawTelemetryPackets].reverse();

  return {
    dryBackLogs: chronologicalLogs.map((log) => {
      const dryBackPercent = log.dry_back ? Number(log.dry_back) : 0;
      const runoffEc = log.runoff_ec ? Number(log.runoff_ec) : 0;

      return {
        id: log.id,
        stage: log.stage || "Flower Room",
        containerGallons: 5,     
        wetWeight: 18.4,         
        dryTargetWeight: 13.2,   
        weight: dryBackPercent,  
        dryBackPercent: dryBackPercent,
        runoff_ec: runoffEc,
        loggedAt: log.created_at ? new Date(log.created_at).toISOString() : new Date().toISOString(),
      };
    }) as any[],

    environmentReadings: chronologicalTelemetry.map((packet) => ({
      id: packet.id,
      temperatureF: Number(packet.temperatureCelsius) * 9 / 5 + 32,
      temperature: Number(packet.temperatureCelsius) * 9 / 5 + 32,
      humidity: Number(packet.relativeHumidity),
      vpd: Number(packet.calculatedVpd),
      runoff_ec: packet.runoffEc ? Number(packet.runoffEc) : 0,
      dry_back: packet.mediaWeightLbs ? Number(packet.mediaWeightLbs) : null,
      recordedAt: packet.recordedAt ? new Date(packet.recordedAt).toISOString() : new Date().toISOString()
    })) as any[]
  };
}

/**
 * INSERTS A LOG INTO THE HISTORYLOGS TABLE (Tenant-Scoped)
 */
export async function addDryBackLog(data: {
  cultivar: string;
  containerGallons: number;
  wetWeight: number;
  dryTargetWeight: number;
  weight: number;
  runoff_ec: number;
}) {
  const userId = await getRequiredUserId();
  const usableDryRange = data.wetWeight - data.dryTargetWeight;
  let dryBackPercentage = 0;
  
  if (usableDryRange > 0) {
    dryBackPercentage = ((data.wetWeight - data.weight) / usableDryRange) * 100;
  }
  
  const guardedPercentage = Math.max(0, Math.min(100, dryBackPercentage));

  return await db.historyLog.create({
    data: {
      userId: userId,
      stage: data.cultivar,
      dry_back: guardedPercentage,
      runoff_ec: data.runoff_ec,
      vpd: 1.2,
    } as any
  });
}

/**
 * PULLS LOGGED PROFILE TO FILTER UI ELEMENTS (Tenant-Scoped)
 */
export async function getUserProfile() {
  try {
    const userId = await getRequiredUserId();
    let profile = await db.userProfile.findFirst({
      where: { id: userId }
    });
    return profile;
  } catch (error) {
    console.error("Failed to query authenticated user profile:", error);
    return null;
  }
}

/**
 * UPDATES USER PROFILE & HARDWARE CONFIGURATION (Tenant-Scoped)
 */
export async function updateUserProfile(data: {
  experienceLevel?: string;
  hasEcmeter?: boolean;
  hasScales?: boolean;
  hasClimateHub?: boolean;
  activeFeedLine?: string;
  controllerBrand?: string;     
  controllerToken?: string;     
  controllerUsername?: string;  
  controllerPassword?: string;  
}) {
  const userId = await getRequiredUserId();
  const current = await db.userProfile.findFirst({
    where: { id: userId }
  });
  
  let updated;

  const payload = {
    experienceLevel: data.experienceLevel,
    hasEcmeter: data.hasEcmeter,
    hasScales: data.hasScales,
    hasClimateHub: data.hasClimateHub,
    activeFeedLine: data.activeFeedLine,
    controllerBrand: data.controllerBrand,     
    controllerToken: data.controllerToken,     
    controllerUsername: data.controllerUsername, 
    controllerPassword: data.controllerPassword  
  };

  if (current) {
    updated = await db.userProfile.update({
      where: { id: current.id },
      data: payload as any 
    });
  } else {
    updated = await db.userProfile.create({
      data: {
        id: userId,
        ...payload,
        experienceLevel: data.experienceLevel ?? "Beginner",
        hasEcmeter: data.hasEcmeter ?? false,
        hasScales: data.hasScales ?? false,
        hasClimateHub: data.hasClimateHub ?? false,
        activeFeedLine: data.activeFeedLine ?? "ff-trio"
      } as any
    });
  }

  revalidatePath("/settings");
  revalidatePath("/");
  return updated;
}

/**
 * NUTRIENT BLUEPRINT MANAGEMENT (Filtered to authenticated user)
 */
export async function getCustomBlueprints() {
  try {
    const userId = await getRequiredUserId();
    const blueprints = await db.$queryRaw<any[]>`
      SELECT id, brand, stage, target_ec::float as target_ec, doses_json, is_custom 
      FROM public.feed_blueprints 
      WHERE user_id = ${userId}
      ORDER BY brand ASC, stage ASC
    `;
    return blueprints || [];
  } catch (error) {
    console.error("Failed to query user-scoped blueprints table:", error);
    return [];
  }
}

export async function saveOrUpdateBlueprint(blueprint: {
  id: string;
  brand: string;
  stage: string;
  target_ec: number;
  doses_json: any;
}) {
  try {
    const userId = await getRequiredUserId();
    const serializedDoses = JSON.stringify(blueprint.doses_json);
    
    // Explicit guard to verify record ownership before modification
    const existing = await db.historyLog.findFirst({
      where: { id: blueprint.id, userId: userId } as any
    });

    await db.$executeRaw`
      INSERT INTO public.feed_blueprints (id, brand, stage, target_ec, doses_json, is_custom, user_id)
      VALUES (${blueprint.id}, ${blueprint.brand}, ${blueprint.stage}, ${blueprint.target_ec}, ${serializedDoses}::jsonb, true, ${userId})
      ON CONFLICT (id) DO UPDATE 
      SET brand = ${blueprint.brand}, 
          stage = ${blueprint.stage}, 
          target_ec = ${blueprint.target_ec}, 
          doses_json = ${serializedDoses}::jsonb,
          is_custom = true
    `;
    
    revalidatePath("/settings");
    revalidatePath("/");
    return { success: true };
  } catch (error: any) {
    console.error("Failed to secure save/update blueprint record:", error);
    return { success: false, error: error.message };
  }
}

export async function deleteCustomBlueprint(id: string) {
  try {
    const userId = await getRequiredUserId();
    await db.$executeRaw`
      DELETE FROM public.feed_blueprints 
      WHERE id = ${id} AND is_custom = true AND user_id = ${userId}
    `;
    revalidatePath("/settings");
    return { success: true };
  } catch (error: any) {
    console.error("Failed to safely delete custom blueprint:", error);
    return { success: false, error: error.message };
  }
}